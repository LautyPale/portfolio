---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import SocialPill from '../components/SocialPill.astro';
import LinkedInIcon from '../components/icons/LinkedIn.astro';
import GitHubIcon from '../components/icons/GitHub.astro';
import MailIcon from '../components/icons/Mail.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Experience from '../components/Experience.astro';
import Briefcase from '../components/icons/Briefcase.astro';
import CodeIcon from '../components/icons/Code.astro';
import Projects from '../components/Projects.astro';

---

<Layout title="Portfolio de Lautaro Palena. - Web Developer and Programmer"
		description="Portfolio de Lautaro Palena. - Trainee Web Developer and Programmer">
	<main class="px-4">

		<SectionContainer class="py-44 pb-32">
			<img 
			class="rounded-full size-12 mb-4" 
			src="../src/images/avatar.png" 
			alt="foto de perfil"
			>
			<h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 pb-6 lg:pb-10">
				Lautaro Palena <a 
					href="https://www.linkedin.com/in/lautaro-palena/"
					target="_blank"
					rel="noopener" 
					class="flex justify-center items-center"
					>
					<Badge>Available for hire</Badge>
				</a>
			</h1>
			<h2 class="text-xl lg:text-3xl text-wrap max-w-[700px]">
				<span class="text-orange-400/90"> Programming and Web Developer student</span>. based in<span class="text-sky-300"> Buenos Aires, Argentina </span>
			</h2>

			<nav class="flex gap-4 mt-4 flex-wrap">

				<SocialPill href="https://www.linkedin.com/in/lautaro-palena/">
					<LinkedInIcon class:list={["size-4 md:size-6"]}/>
					LinkedIn
				</SocialPill>

				<SocialPill href="https://github.com/LautyPale">
					<GitHubIcon class:list={["size-4 md:size-6"]}/>
					GitHub
				</SocialPill>

				<SocialPill href="mailto:palenalautaro@gmail.com">
					<MailIcon class:list={["size-4 md:size-6"]}/>
					palenalautaro@gmail.com
				</SocialPill>

			</nav>

		</SectionContainer>

		<SectionContainer id="experience">
			<h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
				<Briefcase class="size-7" />
				Experience
			</h2>
			<Experience />
		</SectionContainer>

		<SectionContainer id="projects">
			<h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
				<CodeIcon class="size-7" />
				Projects
			</h2>
			<Projects />
		</SectionContainer>

	</main>

</Layout>

