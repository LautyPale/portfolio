---
import Layout from '../layouts/Layout.astro';

import AboutMe from '../components/AboutMe.astro';
import Badge from '../components/Badge.astro';
import SocialPill from '../components/SocialPill.astro';
import LinkedInIcon from '../components/icons/LinkedIn.astro';
import GitHubIcon from '../components/icons/GitHub.astro';
import MailIcon from '../components/icons/Mail.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Experience from '../components/Experience.astro';
import Briefcase from '../components/icons/Briefcase.astro';
import CodeIcon from '../components/icons/Code.astro';
import Projects from '../components/Projects.astro';
import ProfileCheck from '../components/icons/ProfileCheck.astro';

---

<Layout title="Portfolio de Lautaro Palena. - Web Developer and Programmer"
		description="Portfolio de Lautaro Palena. - Trainee Web Developer and Programmer">
	<main class="px-4">


		<SectionContainer class="py-24 pb-32">
			<h1 class="text-gray-900 dark:text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 pb-6 lg:pb-10">
				Lautaro Palena <a 
					href="https://www.linkedin.com/in/lautaro-palena/"
					target="_blank"
					rel="noopener noreferrer"
					class="flex justify-center items-center hover:scale-105 transition"
					>
					<Badge>Disponible para trabajar</Badge>
				</a>
			</h1>
			<h2 
				class="text-xl lg:text-3xl text-wrap max-w-[700px]"
			>
				<span 
				class="text-orange-500 dark:text-orange-400"
				> 
					Estudiante de Programacion y Desarrollo Web</span>. De<span 
					class="text-sky-500 dark:text-sky-300"
					> Buenos Aires, Argentina </span>
			</h2>

			<nav class="flex gap-4 mt-4 flex-wrap">

				<SocialPill href="https://www.linkedin.com/in/lautaro-palena/">
					<LinkedInIcon class:list={["size-4 md:size-6"]}/>
					LinkedIn
				</SocialPill>

				<SocialPill href="https://github.com/LautyPale">
					<GitHubIcon class:list={["size-4 md:size-6"]}/>
					GitHub
				</SocialPill>

				<SocialPill href="mailto:palenalautaro@gmail.com">
					<MailIcon class:list={["size-4 md:size-6"]}/>
					palenalautaro@gmail.com
				</SocialPill>

			</nav>

		</SectionContainer>


		<SectionContainer id="about">
			<h2 
				class="flex items-center mb-6 text-3xl font-semibold gap-x-8 text-white"
			>
			<ProfileCheck class="size-8" />
				Sobre mí
			</h2>
			<AboutMe />
		</SectionContainer>
	
		<SectionContainer id="experience">
			<h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center text-black/80 dark:text-white/80">
				<Briefcase class="size-7" />
				Experiencia
			</h2>
			<Experience />
		</SectionContainer>

		<SectionContainer id="projects">
			<h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center text-black/80 dark:text-white/80">
				<CodeIcon class="size-7" />
				Projectos
			</h2>
			<Projects />
		</SectionContainer>

	</main>

</Layout>

