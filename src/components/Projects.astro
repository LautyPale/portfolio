---
import Javascript from "./icons/Javascript.astro";
import Tailwind from "./icons/Tailwind.astro";
import HTML from "./icons/HTML.astro";
import GitHub from "./icons/GitHub.astro";
import SASS from "./icons/SASS.astro";
import C from "./icons/C.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";

const TAGS = {
    JAVASCRIPT: {
        name: "JavaScript",
        class: "bg-black text-[#f7df1e]",
        icon: Javascript
    },
    TAILWIND: {
        name: "Tailwind CSS",
        class: "bg-[#263e51] text-white",
        icon: Tailwind
    },
    HTML: {
        name: "HTML",
        class: "bg-[#e34c26] text-white",
        icon: HTML
    },
    GitHub: {
        name: "GitHub",
        class: "bg-black text-white",
        icon: GitHub
    },
    SASS: {
        name: "SASS",
        class: "bg-white text-[#cf649a]",
        icon: SASS
    },
    C: {
        name: "C",
        class: "bg-[#f34b7d] text-white",
        icon: C
    }
}
const PROJECTS = [
    {
        title: "Conversos de monedas",
        description: "Un conversor de monedas simple. hecho con JavaScript y Tailwind CSS.",
        link: "https://lautypale.github.io/currency-converter/",
        github: "https://github.com/LautyPale/currency-converter",
        image: "/projects/currency-converter.webp",
        tags: [TAGS.JAVASCRIPT, TAGS.TAILWIND],
    },
    {
        title: "Twenty One Pilots bio",
        description: "Una página de biografía de Twenty One Pilots hecha con HTML y SASS.",
        link: "https://lautypale.github.io/TOP-bio/",
        github: "https://github.com/LautyPale/TOP-bio",
        image: "/projects/TOP-bio.webp",
        tags: [TAGS.JAVASCRIPT, TAGS.SASS],
    }
]
---

<div class="flex flex-col gap-y-16">
    {
      PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
    <div class="w-full md:w-1/2">
      <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
        <img alt="Project image" class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="lazy" src={image} />
      </div>
    </div>
  
    <div class="w-full md:w-1/2 md:max-w-lg">
      <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
        {title}
      </h3>
      <div class="flex flex-wrap mt-2">
        <ul class="flex flex-row mb-2 gap-x-2">
            {tags.map((tag) => (
              <li>
                <span
                  class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                >
                  <tag.icon class="size-4" />
                  {tag.name}
                </span>
              </li>
            ))}
          </ul>
  
        <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
        <footer class="flex items-end justify-start mt-4 gap-x-4">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-6" />
                Code
                
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Link class="size-4" />
                Preview
              </LinkButton>
            )}
          </footer>
      </div>
    </div>
  </article>
      ))
    }
  </div>