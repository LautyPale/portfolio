---
export interface Props {
    title: string
    date: string
    description: string
    link?: string
}

const { title, date, description} = Astro.props
---

<div class="absolute w-3 h-3 rounded-full mt-1.5 -start-1.5 border border-gray-900 bg-gray-700"></div>
        <time 
        class="mb-1 text-sm font-normal leading-none text-orange-500 dark:text-orange-400"
        >{date}</time>
        <h3 
        class="text-lg font-semibold text-sky-500 dark:text-sky-300 mt-2"
        >{title}</h3>
        <p class="mb-4 text-base font-normal text-gray-200 dark:text-gray-100 text-pretty"
        >{description}
        </p>