---
import ExperienceItem from "./ExperienceItem.astro"

const EXPERIENCE = [
    {
        date: '2022 - current',
        title: 'Computer technician and stock manager — ByGamers',
        description: `
            I am currently working as a computer technician and stock manager at a retail store.
            I am in charge of maintaining the store's inventory, providing technical support and resolving customer complaints.`,
        link: '#',
    }
]
---


<ol class="relative border-s border-gray-200 ml-3">           
    {
        EXPERIENCE.map((experience) => (
            <li class="mb-10 ml-6">
                <ExperienceItem {...experience} />
            </li>
        ))
    }       
    
</ol>